# 多模态视觉工具 — 配置文件模板
# 复制此文件为 .env 并填入你的 Key
# .env 文件不要提交到 Git！

# 豆包 API Key（火山引擎 ARK）https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_key_here

# Kimi API Key（月之暗面 Moonshot）https://platform.moonshot.cn
# KIMI_API_KEY=your_kimi_key_here

# 代理设置（可选，如果需要走代理的话）
# VISION_PROXY=http://127.0.0.1:7897
